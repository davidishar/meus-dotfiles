{
    "label" : "lock",
    "action" : "sleep 0.5 && hyprlock",
    "text" : "Bloquear",
    "keybind" : "b"
}
{
    "label" : "hibernate",
    "action" : "sleep 0.5 && systemctl hibernate",
    "text" : "Hibernar",
    "keybind" : "h"
}
{
    "label" : "logout",
    "action" : "hyprctl dispatch 'hl.dsp.exit()'"   
    "text" : "Sair",
    "keybind" : "s"
}
{
    "label" : "suspend",
    "action" : "sleep 0.5 && systemctl suspend",
    "text" : "Suspender",
    "keybind" : "s"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reiniciar",
    "keybind" : "r"
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Desligar",
    "keybind" : "d"
}